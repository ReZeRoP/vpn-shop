# ─── Site ───
# PORT=3000
# DATA_DIR=./data

# ─── Admin bootstrap (used by `npm run db:seed`) ───
ADMIN_USER=admin
ADMIN_PASS=change-me-strong

# ─── 3x-ui panel connection (can also be set in /admin/settings) ───
# Full panel URL INCLUDING the random base path:
XUI_PANEL_URL=https://YOUR_SERVER:2053/YourBasePath
XUI_PANEL_USER=admin
XUI_PANEL_PASS=admin
# v3 panels can use an API token instead of username/password:
# XUI_PANEL_TOKEN=
# 1 if the panel uses a self-signed certificate:
XUI_INSECURE_TLS=1
# Subscription base URL (panel Settings → Subscription):
XUI_SUB_BASE=https://YOUR_SERVER:2096/sub
# Public address used when building direct vless:// links:
XUI_PUBLIC_HOST=YOUR_SERVER
